# =============================================================================
# Error Analysis Tool - Environment Configuration
# =============================================================================
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Settings can also be configured via the UI (Settings tab).
# UI settings override env vars when both are set.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Configuration (Required)
# -----------------------------------------------------------------------------
# OpenAI API key - used by Example Agent and AI features
OPENAI_API_KEY=sk-your-key-here

# Model for AI operations (taxonomy, suggestions, synthetic queries)
# Default: gpt-5-mini. Override in Settings UI per-prompt.
# LLM_MODEL=gpt-5-mini

# Custom LLM API base (for proxies or Azure OpenAI)
# LLM_API_BASE=

# -----------------------------------------------------------------------------
# Weave / W&B Configuration (Optional - can configure in Settings UI)
# -----------------------------------------------------------------------------
# W&B API key for Weave access
# WANDB_API_KEY=

# W&B entity (username or team)
# WANDB_ENTITY=

# Your agent's Weave project (where agent traces are logged)
# WEAVE_PROJECT=

# Tool's Weave project (for internal traces/prompts)
# TOOL_PROJECT_NAME=error-analysis-tool

# Weave API base (for enterprise/self-hosted)
# WEAVE_API_BASE=https://trace.wandb.ai

# -----------------------------------------------------------------------------
# Performance Tuning (Optional)
# -----------------------------------------------------------------------------
# SYNC_QUERY_LIMIT=500        # Max calls per sync
# FEEDBACK_QUERY_LIMIT=500    # Max feedback entries per query
# DEFAULT_BATCH_SIZE=20       # Queries per synthetic batch
# AGENT_QUERY_TIMEOUT=120     # Timeout for agent queries (seconds)
# WEAVE_API_TIMEOUT=60        # Timeout for Weave API calls (seconds)
# HEALTH_CHECK_TIMEOUT=10     # Timeout for health checks (seconds)
# LLM_MAX_CONCURRENT=10       # Max parallel LLM calls

# -----------------------------------------------------------------------------
# Database (Optional)
# -----------------------------------------------------------------------------
# ERROR_ANALYSIS_DB_PATH=./taxonomy.db

# -----------------------------------------------------------------------------
# CORS (Production deployments only)
# -----------------------------------------------------------------------------
# CORS_ORIGINS=https://your-app.com,https://other-origin.com
# CORS_ALLOW_ALL=false

# -----------------------------------------------------------------------------
# Development/Debugging
# -----------------------------------------------------------------------------
# LOG_LEVEL=INFO              # DEBUG, INFO, WARNING, ERROR
# LOG_LLM_CONTENT=false       # Log prompt/response content (privacy risk)
