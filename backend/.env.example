# =============================================================================
# Error Analysis Backend - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# W&B / Weave Configuration (Required)
# -----------------------------------------------------------------------------
# Your Weights & Biases API key (get from: https://wandb.ai/authorize)
WANDB_API_KEY=your_wandb_api_key_here

# Your W&B entity (username or team name)
WANDB_ENTITY=your_entity_here

# Weave project name for traces and prompts
WEAVE_PROJECT=error-analysis-dev

# -----------------------------------------------------------------------------
# LLM Configuration (Required)
# -----------------------------------------------------------------------------
# OpenAI API key for LLM calls (taxonomy categorization, analysis, etc.)
OPENAI_API_KEY=your_openai_api_key_here

# Model to use for categorization (default: gpt-4o-mini)
# CATEGORIZATION_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Logging Configuration (Optional)
# -----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=INFO

# Enable logging of LLM prompt/response content (privacy risk in production)
# LOG_LLM_CONTENT=false

# -----------------------------------------------------------------------------
# Database Configuration (Optional)
# -----------------------------------------------------------------------------
# Path to SQLite database file (default: ./taxonomy.db)
# ERROR_ANALYSIS_DB_PATH=./taxonomy.db

# -----------------------------------------------------------------------------
# CORS Configuration (Optional - for production)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
# CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Allow all origins (development only, not recommended for production)
# CORS_ALLOW_ALL=false
